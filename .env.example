# Copy to .env and fill in. .env is gitignored.

# Anthropic API key, from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Database. Defaults to a local SQLite file (sqlite:///tiny.db) if unset.
# For Postgres: postgresql://user:pass@localhost:5432/tiny
# DATABASE_URL=

# Flask app factory, used by `flask db upgrade`, `flask run`, etc.
FLASK_APP=tiny.app:create_app
